<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:fillViewport="true"
    android:background="@color/gray_100">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/crashTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crash_report_title"
            android:textColor="@android:color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/crashSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crash_report_subtitle"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/crashDetails"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="@android:color/black"
            android:textSize="12sp"
            android:padding="12dp"
            android:background="@android:color/white"
            android:lineSpacingExtra="2dp"
            android:scrollbars="vertical"
            android:textIsSelectable="true" />

        <Button
            android:id="@+id/copyCrashButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/crash_report_copy" />

        <Button
            android:id="@+id/notifyCrashButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/crash_report_notify" />

        <Button
            android:id="@+id/closeCrashButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/crash_report_close" />
    </LinearLayout>
</ScrollView>
