<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- ─── Header Row ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_mic"
            android:tint="#FFEF4444" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Vocalize"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:layout_marginStart="6dp" />

        <TextView
            android:id="@+id/widget_memo_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 memos"
            android:textSize="10sp"
            android:textColor="#70FFFFFF"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/widget_refresh_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_refresh"
            android:tint="#70FFFFFF"
            android:padding="4dp" />

    </LinearLayout>

    <!-- ─── Record Button ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/widget_record_button"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:background="@drawable/widget_record_btn_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_mic"
            android:tint="#FFFFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="New Voice Memo"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFFFF"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="›"
            android:textSize="18sp"
            android:textColor="#AAEF4444" />

    </LinearLayout>

    <!-- ─── Section Label ─────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:text="LAST VOICE MEMO"
        android:textSize="8sp"
        android:textColor="#50FFFFFF"
        android:gravity="center_vertical"
        android:letterSpacing="0.15" />

    <!-- ─── Latest memo preview ───────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="#10FFFFFF">

        <TextView
            android:id="@+id/widget_latest_memo_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textSize="13sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_latest_memo_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#80FFFFFF"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
